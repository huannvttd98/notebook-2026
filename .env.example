# Cổng chạy app (Nginx sẽ proxy về cổng này)
PORT=3100

# Thành phố hiển thị thời tiết (vd: Ho Chi Minh, Ha Noi, Da Nang)
WEATHER_CITY=Ha Noi

# Đặt 'production' khi chạy trên server
NODE_ENV=production

# ===== Đăng nhập Telegram =====
# Chuỗi ký session (đổi thành chuỗi ngẫu nhiên dài: openssl rand -hex 32)
SESSION_SECRET=thay-bang-chuoi-ngau-nhien-dai
# Bot tạo từ @BotFather
TELEGRAM_BOT_TOKEN=
# Tên bot (KHÔNG có @) — dùng cho nút Login Widget
TELEGRAM_BOT_USERNAME=

# Version cache cho CSS/JS — đổi giá trị này khi deploy bản mới (vd 2, 3, 1.0.1)
# để trình duyệt tải lại CSS/JS. Bỏ trống thì server tự dùng thời gian sửa file.
ASSET_VERSION=1
