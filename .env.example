# Cổng chạy app (Nginx sẽ proxy về cổng này)
PORT=3000

# Chuỗi bí mật ký session — đổi thành chuỗi ngẫu nhiên dài (vd: openssl rand -hex 32)
SESSION_SECRET=thay-bang-chuoi-ngau-nhien-dai

# Hash bcrypt của mật khẩu đăng nhập — tạo bằng: npm run set-password
APP_PASSWORD_HASH=

# Đặt 'production' khi chạy trên server (bật cookie secure qua HTTPS)
NODE_ENV=development

# Thành phố hiển thị thời tiết (vd: Ho Chi Minh, Ha Noi, Da Nang)
WEATHER_CITY=Ho Chi Minh
