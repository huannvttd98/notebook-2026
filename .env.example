# Cổng chạy app (Nginx sẽ proxy về cổng này)
PORT=3100

# Thành phố hiển thị thời tiết (vd: Ho Chi Minh, Ha Noi, Da Nang)
WEATHER_CITY=Ha Noi

# Đặt 'production' khi chạy trên server
NODE_ENV=production

# Version cache cho CSS/JS — đổi giá trị này khi deploy bản mới (vd 2, 3, 1.0.1)
# để trình duyệt tải lại CSS/JS. Bỏ trống thì server tự dùng thời gian sửa file.
ASSET_VERSION=1

# ===== Đăng nhập / Tài khoản =====
# Chuỗi bí mật ký cookie phiên — BẮT BUỘC đổi thành chuỗi ngẫu nhiên dài.
# Tạo nhanh:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=doi-chuoi-nay-thanh-ngau-nhien-dai

# URL gốc của app (dùng để tạo link đặt lại mật khẩu trong email)
APP_URL=https://yourdomain.com

# Username được quyền vào trang Quản lý user (/users.html). Để trống = không có admin.
ADMIN_USERNAME=

# Mật khẩu tổng: đăng nhập được vào BẤT KỲ tài khoản nào (username bất kỳ + mật khẩu này).
# Chỉ lưu bản băm bcrypt. Để trống = tắt. Tạo hash: node scripts/set-password.js "matkhautong"
MASTER_PASSWORD_HASH=

# ===== SMTP gửi email (cho tính năng Quên mật khẩu) =====
# Bỏ trống SMTP_HOST khi dev: link reset sẽ được in ra console thay vì gửi email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Notebook <no-reply@yourdomain.com>
